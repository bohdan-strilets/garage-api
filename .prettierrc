{
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.json",
      "options": { "tabWidth": 2 }
    },
    {
      "files": "*.md",
      "options": { "tabWidth": 2 }
    },
    {
      "files": "*.yml",
      "options": { "tabWidth": 2 }
    },
    {
      "files": "*.yaml",
      "options": { "tabWidth": 2 }
    }
  ]
}
